    def _go_to_action(self):
        targets = self._selected_nodes()
        if not targets:
            return
        n = len(targets)
        self._target_label.setText(
            f"Targeting {n} node{'s' if n != 1 else ''}")
        self._stack.setCurrentIndex(1)
        self._stepbar.set_step(1)

    def _go_to_results(self):
        self._stack.setCurrentIndex(2)
        self._stepbar.set_step(2)

    def _go_back(self):
        idx = self._stack.currentIndex()
        if idx > 0:
            self._stack.setCurrentIndex(idx - 1)
            self._stepbar.set_step(idx - 1)

    def _go_to_start(self):
        self._reset_action_form()
        self._stack.setCurrentIndex(0)
        self._stepbar.set_step(0)

    def _reset_action_form(self):
        self._radio_cmd.setChecked(True)
        self._form_stack.setCurrentIndex(0)
        self.cmd_input.clear()
        self.cmd_timeout.setValue(0)
        self.cmd_sudo.setChecked(False)
        self.copy_src.clear()
        self.copy_dest.clear()
        self.copy_timeout.setValue(0)
        self.copy_sudo.setChecked(False)

    def _dispatch_run(self):
        # Prepare targets and params, then start worker thread to perform actions
        targets = self._selected_nodes()
        if not targets:
            return

        if self._radio_cmd.isChecked():
            action = "command"
            params = {
                'command': self.cmd_input.text().strip() or "echo hello",
                'sudo': self.cmd_sudo.isChecked(),
                'timeout': int(self.cmd_timeout.value()),
            }
        else:
            action = "copy"
            params = {
                'src': self.copy_src.text().strip(),
                'dest': self.copy_dest.text().strip(),
                'sudo': self.copy_sudo.isChecked(),
                'timeout': int(self.copy_timeout.value()),
            }

        self._run_btn.setEnabled(False)
        self._run_btn.setText("Running…")
        self.results_table.setRowCount(0)
        self.log_view.clear()
        self._go_to_results()

        self._worker = RunWorker(action, targets, params)
        self._thread = QThread()
        self._worker.moveToThread(self._thread)
        self._thread.started.connect(self._worker.run)
        self._worker.signals.progress.connect(self._on_worker_progress)
        self._worker.signals.error.connect(self._on_worker_error)
        self._worker.signals.finished.connect(self._on_worker_finished)
        self._thread.start()

    def _on_action_toggled(self, btn_id: int, checked: bool):
        if checked:
            self._form_stack.setCurrentIndex(btn_id)

    def _refresh_sel_label(self):
        count = sum(
            1 for row in range(self.inv_table.rowCount())
            if self.inv_table.item(row, 0)
            and self.inv_table.item(row, 0).checkState() == Qt.Checked
        )
        self._sel_label.setText(
            f"{count} node{'s' if count != 1 else ''} selected")
        self._next_btn.setEnabled(count > 0)

    def _clear_results(self):
        self.results_table.setRowCount(0)
        self.log_view.clear()

    def _on_worker_progress(self, res: dict):
        from utils import strip_rich

        name = res.get('node') or str(res.get('host', ''))
        clean_status = strip_rich(res.get('status', ''))
        display = res.get('display', '')
        logpath = res.get('log')

        row = self.results_table.rowCount()
        self.results_table.insertRow(row)
        item = QTableWidgetItem(name)
        item.setData(Qt.UserRole, logpath if logpath and logpath != '-' else None)
        item.setData(Qt.UserRole + 1, display)
        self.results_table.setItem(row, 0, item)
        self.results_table.setItem(row, 1, QTableWidgetItem(clean_status))

    def _on_worker_error(self, tb: str):
        # show traceback in log view
        self.log_view.setPlainText(tb)

    def _on_worker_finished(self):
        self._run_btn.setEnabled(True)
        self._run_btn.setText("▶  Run")
        try:
            self._thread.quit()
            self._thread.wait(1000)
        except Exception:
            pass

    # ── data ─────────────────────────────────────────────────────────────────

    def load_inventory(self):
        try:
            from utils import load_inventory
        except Exception as e:
            self.inv_table.setRowCount(1)
            self.inv_table.setItem(
                0, 1, QTableWidgetItem(f"Error loading utils: {e}"))
            return

        try:
            nodes = load_inventory(self.inventory_path)
        except SystemExit:
            self.inv_table.setRowCount(1)
            self.inv_table.setItem(0, 1, QTableWidgetItem(
                f"Inventory not found or invalid: {self.inventory_path}"))
            return
        except Exception as e:
            self.inv_table.setRowCount(1)
            self.inv_table.setItem(0, 1, QTableWidgetItem(f"Error: {e}"))
            return

        selected_group = self.group_filter.currentText()
        all_groups = sorted({n.get('group', '')
                            for n in nodes if n.get('group')})
        if selected_group and selected_group != "(All)":
            nodes = [n for n in nodes if n.get('group') == selected_group]

        self._nodes = nodes
        self.inv_table.blockSignals(True)
        self.inv_table.setRowCount(0)
        self.group_filter.blockSignals(True)
        try:
            self.group_filter.clear()
            self.group_filter.addItem("(All)")
            for g in all_groups:
                self.group_filter.addItem(g)

            for n in nodes:
                row = self.inv_table.rowCount()
                self.inv_table.insertRow(row)
                chk = QTableWidgetItem()
                chk.setFlags(Qt.ItemIsUserCheckable | Qt.ItemIsEnabled)
                chk.setCheckState(Qt.Checked)
                self.inv_table.setItem(row, 0, chk)
                self.inv_table.setItem(
                    row, 1, QTableWidgetItem(n.get('name', '')))
                self.inv_table.setItem(
                    row, 2, QTableWidgetItem(n.get('host', '')))
                self.inv_table.setItem(
                    row, 3, QTableWidgetItem(n.get('user', '')))
                self.inv_table.setItem(
                    row, 4, QTableWidgetItem(n.get('group', '')))

            if selected_group and selected_group != "(All)":
                idx = self.group_filter.findText(selected_group)
                if idx >= 0:
                    self.group_filter.setCurrentIndex(idx)
        finally:
            self.group_filter.blockSignals(False)
            self.inv_table.blockSignals(False)

        self._refresh_sel_label()

    def browse_src(self):
        path, _ = QFileDialog.getOpenFileName(self, "Select file to copy")
        if path:
            self.copy_src.setText(path)

    def browse_inventory(self):
        path, _ = QFileDialog.getOpenFileName(
            self, "Select inventory YAML",
            filter="YAML Files (*.yml *.yaml);;All Files (*)")
        if path:
            self.inventory_path = path
            self.inv_path_edit.setText(path)
            self.load_inventory()

    def _selected_nodes(self) -> List[dict]:
        result = []
        for row in range(self.inv_table.rowCount()):
            chk = self.inv_table.item(row, 0)
            if chk and chk.checkState() == Qt.Checked and row < len(self._nodes):
                result.append(self._nodes[row])
        return result

    def on_result_selected(self, row: int, col: int):
        item = self.results_table.item(row, 0)
        if not item:
            return
        logpath = item.data(Qt.UserRole)
        fallback = item.data(Qt.UserRole + 1) or ""
        if logpath:
            try:
                self.log_view.setPlainText(Path(logpath).read_text(errors='replace'))
                return
            except Exception as e:
                fallback = f"[Could not read log file: {e}]\n\n{fallback}"
        self.log_view.setPlainText(fallback)


def main():
    app = QApplication(sys.argv)
    _setup_app(app)
    w = MainWindow()
    w.show()
    sys.exit(app.exec())


if __name__ == "__main__":
    main()
