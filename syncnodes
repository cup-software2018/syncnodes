def find_inventory_path() -> str:
    cwd_candidate = Path.cwd() / "nodes.yml"
    repo_candidate = ROOT / "nodes.yml"
    if cwd_candidate.exists():
        return str(cwd_candidate)
    if repo_candidate.exists():
        return str(repo_candidate)
    return str(cwd_candidate)


class WorkerSignals(QObject):
    progress = Signal(object)  # emits a single result dict
    finished = Signal()
    error = Signal(str)


class RunWorker(QObject):
    """Worker that runs async nodectl/copyctl functions in a separate thread.

    Emits progress signals for each node result and a finished signal when done.
    """

    def __init__(self, action: str, nodes: list, params: dict):
        super().__init__()
        self.signals = WorkerSignals()
        self._action = action
        self._nodes = nodes
        self._params = params

    def run(self):
        try:
            import asyncio
            from utils import run_command_on_node, copy_file_to_node

            if self._action == "command":
                fn = run_command_on_node
                args = (self._params.get('command', ''),
                        self._params.get('sudo', False),
                        self._params.get('timeout', 0))
            elif self._action == "copy":
                fn = copy_file_to_node
                args = (self._params.get('src', ''),
                        self._params.get('dest', ''),
                        self._params.get('sudo', False),
                        self._params.get('timeout', 0))
            else:
                self.signals.error.emit(f"Unknown action: {self._action}")
                return

            async def _runner():
                tasks = [fn(n, *args) for n in self._nodes]
                for coro in asyncio.as_completed(tasks):
                    self.signals.progress.emit(await coro)

            asyncio.run(_runner())
        except Exception:
            import traceback
            self.signals.error.emit(traceback.format_exc())
        finally:
            self.signals.finished.emit()


class SectionLabel(QLabel):
    def __init__(self, text, parent=None):
        super().__init__(text.upper(), parent)
        self.setStyleSheet(
            "color: #9a9996; font-size: 10px; font-weight: bold; letter-spacing: 2px;"
        )


class StepBar(QWidget):
    _STEPS = ["① Select Nodes", "② Set Action", "③ Results"]

    def __init__(self, parent=None):
        super().__init__(parent)
        layout = QHBoxLayout(self)
        layout.setContentsMargins(20, 0, 20, 0)
        layout.setSpacing(6)
        self._labels: List[QLabel] = []
        for i, name in enumerate(self._STEPS):
            lbl = QLabel(name)
            self._labels.append(lbl)
            layout.addWidget(lbl)
            if i < len(self._STEPS) - 1:
                arr = QLabel("──▶")
                arr.setStyleSheet("color: #c0bfbd; font-size: 10px;")
                layout.addWidget(arr)
        layout.addStretch()
        self._refresh(0)

    def set_step(self, step: int):
        self._current = step
        self._refresh(step)

    def _refresh(self, step: int):
        for i, lbl in enumerate(self._labels):
            if i == step:
                lbl.setStyleSheet(
                    "color: #3584e4; font-weight: bold; font-size: 15px;")
            elif i < step:
                lbl.setStyleSheet("color: #9a9996; font-size: 15px;")
            else:
                lbl.setStyleSheet("color: #c0bfbd; font-size: 15px;")


