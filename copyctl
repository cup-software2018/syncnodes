#!/usr/bin/env python3

import os
import sys
import asyncio
import argparse
from utils import load_inventory, copy_file_to_node, strip_rich


async def main():
    parser = argparse.ArgumentParser(description="syncnodes File Copy Tool (copyctl)")
    parser.add_argument("-i", "--inventory", default="nodes.yml",
                        help="Path to the inventory YAML file")
    parser.add_argument("-s", "--src", required=True, help="Local source file/dir path")
    parser.add_argument("-d", "--dest", required=True, help="Remote destination path")
    parser.add_argument("--sudo", action="store_true",
                        help="Copy with sudo (changes ownership to root)")
    parser.add_argument("-g", "--group", help="Target a specific group from nodes.yml")
    parser.add_argument("-t", "--timeout", type=int, default=0,
                        help="Timeout in seconds")
    parser.add_argument("--no-rich", action="store_true", help="Disable Rich UI output")

    args = parser.parse_args()

    if not os.path.exists(args.src):
        print(f"Error: '{args.src}' does not exist.")
        sys.exit(1)

    nodes = load_inventory(args.inventory)
    if args.group:
        nodes = [n for n in nodes if n.get('group') == args.group]
    if not nodes:
        print("No target nodes found.")
        sys.exit(0)

    tasks = [copy_file_to_node(n, args.src, args.dest, args.sudo, args.timeout) for n in nodes]

    if not args.no_rich:
        try:
            from rich.console import Console
            from rich.table import Table
            console = Console()
            with console.status(f"[bold cyan]Pushing '{args.src}' to {len(nodes)} nodes...[/]", spinner="dots"):
                results = await asyncio.gather(*tasks)
            table = Table(title="Copy Summary", show_header=True, header_style="bold magenta")
            table.add_column("Node", style="cyan")
            table.add_column("Host", style="blue")
            table.add_column("Status")
            table.add_column("Details", style="dim")
            for res in results:
                table.add_row(res['node'], res['host'], res['status'], res['display'])
            console.print(table)
            return
        except ImportError:
            print("Warning: 'rich' not installed, falling back to plain output.\n")

    print(f"Copying '{args.src}' to {len(nodes)} nodes...\n" + "=" * 50)
    results = await asyncio.gather(*tasks)
    for res in results:
        status = strip_rich(res['status'])
        print(f"[{res['node']} ({res['host']})] {status} -> {res['display']}")


if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        print("\nExecution canceled by user.")
